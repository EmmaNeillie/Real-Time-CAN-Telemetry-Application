<Page x:Class="WPF_CAN_Tool.Pages.PedalsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Pedals"
      Background="Black">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Page Title -->
            <TextBlock Grid.Row="0"
                       Text="Pedals"
                       Foreground="#FFD700"
                       FontSize="34"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <!-- Pedal Cards -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ══════════════════════════════════════
                     ACCELERATOR
                ══════════════════════════════════════ -->
                <Border Grid.Column="0"
                        BorderBrush="#FFD700"
                        BorderThickness="2"
                        CornerRadius="10"
                        Margin="10"
                        Padding="15">
                    <StackPanel>

                        <TextBlock Text="Accelerator"
                                   Foreground="White"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,16"/>

                        <!-- Side-view pedal diagram -->
                        <!--
                            Layout (280 × 260 canvas):
                              Pivot:     (140, 220)   — bolted to floor rail
                              Arm rest:  tip at (140, 60) = straight up
                              Arm rotates clockwise as pedal is pressed.
                              Footplate is a short bar perpendicular to the arm tip.

                            RotateTransform is applied to the entire arm+footplate
                            group, centred on the pivot point (140, 220).
                        -->
                        <Canvas Width="280" Height="260" HorizontalAlignment="Center">

                            <!-- Floor rail -->
                            <Rectangle Canvas.Left="20"  Canvas.Top="228"
                                       Width="240" Height="8"
                                       RadiusX="3" RadiusY="3"
                                       Fill="#333333"
                                       Stroke="#888888"
                                       StrokeThickness="1"/>

                            <!-- Arc showing travel range (approx 0–40°) -->
                            <Path Stroke="#444444"
                                  StrokeThickness="1"
                                  StrokeDashArray="4 3"
                                  Fill="Transparent"
                                  Data="M 140,160 A 60,60 0 0 1 179,165"/>

                            <!-- Pedal arm + footplate group, rotating around pivot -->
                            <Canvas Canvas.Left="0" Canvas.Top="0">
                                <Canvas.RenderTransform>
                                    <RotateTransform Angle="{Binding AcceleratorAngle}"
                                                     CenterX="140"
                                                     CenterY="220"/>
                                </Canvas.RenderTransform>

                                <!-- Arm body: from pivot (140,220) up to (140,60) -->
                                <Line X1="140" Y1="220"
                                      X2="140" Y2="60"
                                      Stroke="#FFD700"
                                      StrokeThickness="9"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"/>

                                <!-- Footplate: centred on arm tip (140,60), horizontal -->
                                <Line X1="108" Y1="60"
                                      X2="172" Y2="60"
                                      Stroke="#FFD700"
                                      StrokeThickness="7"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"/>

                                <!-- Footplate grip ridges -->
                                <Line X1="118" Y1="60" X2="118" Y2="52"
                                      Stroke="#CC9900" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="130" Y1="60" X2="130" Y2="52"
                                      Stroke="#CC9900" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="142" Y1="60" X2="142" Y2="52"
                                      Stroke="#CC9900" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="154" Y1="60" X2="154" Y2="52"
                                      Stroke="#CC9900" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="166" Y1="60" X2="166" Y2="52"
                                      Stroke="#CC9900" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>

                            </Canvas>

                            <!-- Pivot housing (drawn last so it sits on top) -->
                            <!-- Outer ring -->
                            <Ellipse Width="22" Height="22"
                                     Canvas.Left="129" Canvas.Top="209"
                                     Fill="#1A1A1A"
                                     Stroke="#FFD700"
                                     StrokeThickness="2.5"/>
                            <!-- Bolt centre -->
                            <Ellipse Width="8" Height="8"
                                     Canvas.Left="136" Canvas.Top="216"
                                     Fill="#FFD700"/>

                            <!-- Angle arc indicator -->
                            <Path Stroke="#FFD700"
                                  StrokeThickness="1.5"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Fill="Transparent">
                                <Path.Data>
                                    <PathGeometry>
                                        <PathFigure StartPoint="140,190">
                                            <ArcSegment Size="30,30"
                                                        IsLargeArc="False"
                                                        SweepDirection="Clockwise">
                                                <ArcSegment.Point>
                                                    <Point X="170" Y="200"/>
                                                </ArcSegment.Point>
                                            </ArcSegment>
                                        </PathFigure>
                                    </PathGeometry>
                                </Path.Data>
                                <Path.RenderTransform>
                                    <RotateTransform Angle="{Binding AcceleratorAngle}"
                                                     CenterX="140"
                                                     CenterY="220"/>
                                </Path.RenderTransform>
                            </Path>

                        </Canvas>

                        <!-- Readouts -->
                        <TextBlock Text="{Binding AcceleratorPercentage, StringFormat={}{0:F1}%}"
                                   Foreground="#FFD700"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,12,0,4"/>

                        <TextBlock Text="{Binding AcceleratorAngle, StringFormat=Angle: {0:F1}°}"
                                   Foreground="White"
                                   FontSize="18"
                                   HorizontalAlignment="Center"/>

                    </StackPanel>
                </Border>

                <!-- ══════════════════════════════════════
                     BRAKE
                ══════════════════════════════════════ -->
                <Border Grid.Column="1"
                        BorderBrush="#FFD700"
                        BorderThickness="2"
                        CornerRadius="10"
                        Margin="10"
                        Padding="15">
                    <StackPanel>

                        <TextBlock Text="Brake"
                                   Foreground="White"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,16"/>

                        <Canvas Width="280" Height="260" HorizontalAlignment="Center">

                            <!-- Floor rail -->
                            <Rectangle Canvas.Left="20" Canvas.Top="228"
                                       Width="240" Height="8"
                                       RadiusX="3" RadiusY="3"
                                       Fill="#333333"
                                       Stroke="#888888"
                                       StrokeThickness="1"/>

                            <!-- Arc showing travel range -->
                            <Path Stroke="#444444"
                                  StrokeThickness="1"
                                  StrokeDashArray="4 3"
                                  Fill="Transparent"
                                  Data="M 140,160 A 60,60 0 0 1 179,165"/>

                            <!-- Pedal arm + footplate group -->
                            <Canvas Canvas.Left="0" Canvas.Top="0">
                                <Canvas.RenderTransform>
                                    <RotateTransform Angle="{Binding BrakeAngle}"
                                                     CenterX="140"
                                                     CenterY="220"/>
                                </Canvas.RenderTransform>

                                <!-- Arm body -->
                                <Line X1="140" Y1="220"
                                      X2="140" Y2="60"
                                      Stroke="#FF5555"
                                      StrokeThickness="9"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"/>

                                <!-- Footplate -->
                                <Line X1="108" Y1="60"
                                      X2="172" Y2="60"
                                      Stroke="#FF5555"
                                      StrokeThickness="7"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"/>

                                <!-- Footplate grip ridges -->
                                <Line X1="118" Y1="60" X2="118" Y2="52"
                                      Stroke="#CC2222" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="130" Y1="60" X2="130" Y2="52"
                                      Stroke="#CC2222" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="142" Y1="60" X2="142" Y2="52"
                                      Stroke="#CC2222" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="154" Y1="60" X2="154" Y2="52"
                                      Stroke="#CC2222" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="166" Y1="60" X2="166" Y2="52"
                                      Stroke="#CC2222" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>

                            </Canvas>

                            <!-- Pivot housing -->
                            <Ellipse Width="22" Height="22"
                                     Canvas.Left="129" Canvas.Top="209"
                                     Fill="#1A1A1A"
                                     Stroke="#FF5555"
                                     StrokeThickness="2.5"/>
                            <Ellipse Width="8" Height="8"
                                     Canvas.Left="136" Canvas.Top="216"
                                     Fill="#FF5555"/>

                        </Canvas>

                        <!-- Readouts -->
                        <TextBlock Text="{Binding BrakePercentage, StringFormat={}{0:F1}%}"
                                   Foreground="#FFD700"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,12,0,4"/>

                        <TextBlock Text="{Binding BrakeAngle, StringFormat=Angle: {0:F1}°}"
                                   Foreground="White"
                                   FontSize="18"
                                   HorizontalAlignment="Center"/>

                    </StackPanel>
                </Border>

            </Grid>

            <!-- ══════════════════════════════════════
                 Status row
            ══════════════════════════════════════ -->
            <UniformGrid Grid.Row="2" Columns="2" Margin="0,20,0,0">
                <Border BorderBrush="#FFD700" BorderThickness="1" CornerRadius="8" Margin="8" Padding="12">
                    <StackPanel>
                        <TextBlock Text="BOTS Status"
                                   Foreground="White"
                                   FontSize="18"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding BOTSStatus}"
                                   Foreground="Lime"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#FFD700" BorderThickness="1" CornerRadius="8" Margin="8" Padding="12">
                    <StackPanel>
                        <TextBlock Text="APPS Status"
                                   Foreground="White"
                                   FontSize="18"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding APPSStatus}"
                                   Foreground="Lime"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

        </Grid>
    </ScrollViewer>
</Page>
