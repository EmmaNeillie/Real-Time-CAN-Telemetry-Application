<Page x:Class="WPF_CAN_Tool.Pages.LvOverviewPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="LV Overview"
      Background="Black">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="LV Overview"
                       Foreground="#FFD700"
                       FontSize="34"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <!-- Main live values -->
            <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,20">

                <Border BorderBrush="#FFD700" BorderThickness="2" CornerRadius="8" Margin="6" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Accelerator"
                                   Foreground="White"
                                   FontSize="18"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding AcceleratorPercentage, StringFormat={}{0:F1}%}"
                                   Foreground="#FFD700"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#FFD700" BorderThickness="2" CornerRadius="8" Margin="6" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Brake"
                                   Foreground="White"
                                   FontSize="18"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding BrakePercentage, StringFormat={}{0:F1}%}"
                                   Foreground="#FFD700"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#FFD700" BorderThickness="2" CornerRadius="8" Margin="6" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Motor RPM"
                                   Foreground="White"
                                   FontSize="18"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding MotorRpm, StringFormat={}{0:F0} rpm}"
                                   Foreground="#FFD700"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#FFD700" BorderThickness="2" CornerRadius="8" Margin="6" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Energy Setting"
                                   Foreground="White"
                                   FontSize="18"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding EnergySetting}"
                                   Foreground="#FFD700"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#FFD700" BorderThickness="2" CornerRadius="8" Margin="6" Padding="12">
                    <StackPanel>
                        <TextBlock Text="BOTS Status"
                                   Foreground="White"
                                   FontSize="18"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding BOTSStatus}"
                                   Foreground="Lime"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#FFD700" BorderThickness="2" CornerRadius="8" Margin="6" Padding="12">
                    <StackPanel>
                        <TextBlock Text="APPS Status"
                                   Foreground="White"
                                   FontSize="18"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding APPSStatus}"
                                   Foreground="Lime"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Wheel section -->
            <GroupBox Grid.Row="2"
                      Header="Wheel Speeds / Brake Temps"
                      Foreground="#FFD700"
                      BorderBrush="#FFD700"
                      Margin="0,0,0,20"
                      Padding="10">
                <UniformGrid Columns="2">

                    <Border BorderBrush="Gray" BorderThickness="1" Margin="5" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Front Left" Foreground="White" FontWeight="Bold" FontSize="18"/>
                            <TextBlock Text="{Binding FLWheelspeed, StringFormat=Speed: {0}}" Foreground="White" FontSize="16"/>
                            <TextBlock Text="{Binding FLBrakeTemp, StringFormat=Brake Temp: {0} °C}" Foreground="White" FontSize="16"/>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="Gray" BorderThickness="1" Margin="5" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Front Right" Foreground="White" FontWeight="Bold" FontSize="18"/>
                            <TextBlock Text="{Binding FRWheelspeed, StringFormat=Speed: {0}}" Foreground="White" FontSize="16"/>
                            <TextBlock Text="{Binding FRBrakeTemp, StringFormat=Brake Temp: {0} °C}" Foreground="White" FontSize="16"/>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="Gray" BorderThickness="1" Margin="5" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Rear Left" Foreground="White" FontWeight="Bold" FontSize="18"/>
                            <TextBlock Text="{Binding RLWheelspeed, StringFormat=Speed: {0}}" Foreground="White" FontSize="16"/>
                            <TextBlock Text="{Binding RLBrakeTemp, StringFormat=Brake Temp: {0} °C}" Foreground="White" FontSize="16"/>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="Gray" BorderThickness="1" Margin="5" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Rear Right" Foreground="White" FontWeight="Bold" FontSize="18"/>
                            <TextBlock Text="{Binding RRWheelspeed, StringFormat=Speed: {0}}" Foreground="White" FontSize="16"/>
                            <TextBlock Text="{Binding RRBrakeTemp, StringFormat=Brake Temp: {0} °C}" Foreground="White" FontSize="16"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </GroupBox>

            <!-- Raw CAN message list -->
            <Border Grid.Row="3" BorderBrush="#FFD700" BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel>
                    <TextBlock Text="Raw CAN / Status Area"
                               Foreground="#FFD700"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>
                    <Border BorderBrush="#333333"
                            BorderThickness="1"
                            Background="#101010"
                            Padding="8"
                            MinHeight="180"
                            MaxHeight="320">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding RawCanMessages}"
                                       Foreground="White"
                                       FontFamily="Consolas"
                                       FontSize="13"
                                       TextWrapping="NoWrap"/>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
