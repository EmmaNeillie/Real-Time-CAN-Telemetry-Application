<Page x:Class="WPF_CAN_Tool.Pages.WheelspeedsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="WheelSpeeds"
      Background="Black">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Page Title -->
            <TextBlock Grid.Row="0"
                       Text="Wheel Speeds"
                       Foreground="#FFD700"
                       FontSize="34"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <!-- ══════════════════════════════════════════════════════
                 Car diagram + wheel data panels
                 Canvas: 960 × 600
                 Car body centre X = 480, nose at top (Y≈30), rear at Y≈560
                 Tyre positions (centre):
                   FL: (310, 155)   FR: (650, 155)
                   RL: (310, 430)   RR: (650, 430)
            ══════════════════════════════════════════════════════ -->
            <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Canvas Width="960" Height="600">

                    <!-- ─────────────────────────────────────────────
                         TOP-VIEW FORMULA CAR BODY
                    ───────────────────────────────────────────── -->

                    <!-- FRONT WING assembly -->
                    <!-- Main plane -->
                    <Rectangle Canvas.Left="362" Canvas.Top="14"
                               Width="256" Height="18"
                               RadiusX="4" RadiusY="4"
                               Fill="#1C1C1C" Stroke="#FFD700" StrokeThickness="1.5"/>
                    <!-- End plates FL -->
                    <Rectangle Canvas.Left="358" Canvas.Top="10"
                               Width="10" Height="26"
                               RadiusX="2" RadiusY="2"
                               Fill="#1C1C1C" Stroke="#FFD700" StrokeThickness="1"/>
                    <!-- End plates FR -->
                    <Rectangle Canvas.Left="612" Canvas.Top="10"
                               Width="10" Height="26"
                               RadiusX="2" RadiusY="2"
                               Fill="#1C1C1C" Stroke="#FFD700" StrokeThickness="1"/>
                    <!-- Second flap -->
                    <Rectangle Canvas.Left="374" Canvas.Top="32"
                               Width="232" Height="10"
                               RadiusX="2" RadiusY="2"
                               Fill="#252525" Stroke="#888" StrokeThickness="1"/>

                    <!-- NOSE CONE: tapered from front wing root down to monocoque -->
                    <Polygon Points="480,32 420,105 540,105"
                             Fill="#1A1A1A" Stroke="#FFD700" StrokeThickness="1.5"/>
                    <!-- Nose undercut shading -->
                    <Polygon Points="480,40 432,100 528,100"
                             Fill="#111111" Stroke="#444" StrokeThickness="0.5"/>

                    <!-- MONOCOQUE / tub (main chassis) -->
                    <Path Fill="#1E1E1E" Stroke="#FFD700" StrokeThickness="2"
                          Data="M 420,105
                                L 398,130
                                L 390,200
                                L 390,340
                                L 400,380
                                L 420,400
                                L 540,400
                                L 560,380
                                L 570,340
                                L 570,200
                                L 562,130
                                L 540,105
                                Z"/>

                    <!-- COCKPIT opening -->
                    <Path Fill="#0A0A0A" Stroke="#666" StrokeThickness="1"
                          Data="M 452,140
                                C 452,135 468,128 480,128
                                C 492,128 508,135 508,140
                                L 514,230
                                C 514,238 498,244 480,244
                                C 462,244 446,238 446,230
                                Z"/>

                    <!-- Headrest / roll hoop -->
                    <Ellipse Canvas.Left="464" Canvas.Top="120"
                             Width="32" Height="20"
                             Fill="#0D0D0D" Stroke="#888" StrokeThickness="1.5"/>

                    <!-- Halo -->
                    <Path Fill="Transparent" Stroke="#AAA" StrokeThickness="2.5"
                          Data="M 458,148 C 458,135 502,135 502,148"/>
                    <Rectangle Canvas.Left="476" Canvas.Top="130"
                               Width="8" Height="18"
                               RadiusX="3" RadiusY="3"
                               Fill="#888" Stroke="#AAA" StrokeThickness="1"/>

                    <!-- LEFT SIDEPOD -->
                    <Path Fill="#161616" Stroke="#888" StrokeThickness="1.5"
                          Data="M 390,200
                                L 348,210
                                L 332,240
                                L 330,300
                                L 342,330
                                L 360,340
                                L 390,340
                                Z"/>
                    <!-- Left sidepod inlet -->
                    <Path Fill="#0A0A0A" Stroke="#666" StrokeThickness="1"
                          Data="M 356,218 L 340,225 L 340,260 L 356,265 Z"/>

                    <!-- RIGHT SIDEPOD -->
                    <Path Fill="#161616" Stroke="#888" StrokeThickness="1.5"
                          Data="M 570,200
                                L 612,210
                                L 628,240
                                L 630,300
                                L 618,330
                                L 600,340
                                L 570,340
                                Z"/>
                    <!-- Right sidepod inlet -->
                    <Path Fill="#0A0A0A" Stroke="#666" StrokeThickness="1"
                          Data="M 604,218 L 620,225 L 620,260 L 604,265 Z"/>

                    <!-- ENGINE COVER / shark fin area -->
                    <Path Fill="#181818" Stroke="#666" StrokeThickness="1"
                          Data="M 450,250
                                L 450,360
                                L 510,360
                                L 510,250
                                Z"/>
                    <!-- Engine detail lines -->
                    <Line X1="460" Y1="270" X2="460" Y2="355" Stroke="#333" StrokeThickness="1"/>
                    <Line X1="480" Y1="265" X2="480" Y2="358" Stroke="#333" StrokeThickness="1"/>
                    <Line X1="500" Y1="270" X2="500" Y2="355" Stroke="#333" StrokeThickness="1"/>

                    <!-- DIFFUSER / rear body -->
                    <Path Fill="#1A1A1A" Stroke="#FFD700" StrokeThickness="1.5"
                          Data="M 420,400
                                L 415,435
                                L 420,455
                                L 540,455
                                L 545,435
                                L 540,400
                                Z"/>
                    <!-- Diffuser channels -->
                    <Line X1="440" Y1="405" X2="438" Y2="450" Stroke="#333" StrokeThickness="1"/>
                    <Line X1="460" Y1="402" X2="460" Y2="452" Stroke="#333" StrokeThickness="1"/>
                    <Line X1="480" Y1="401" X2="480" Y2="453" Stroke="#333" StrokeThickness="1"/>
                    <Line X1="500" Y1="402" X2="500" Y2="452" Stroke="#333" StrokeThickness="1"/>
                    <Line X1="520" Y1="405" X2="522" Y2="450" Stroke="#333" StrokeThickness="1"/>

                    <!-- REAR WING -->
                    <!-- Main element -->
                    <Rectangle Canvas.Left="380" Canvas.Top="460"
                               Width="200" Height="22"
                               RadiusX="4" RadiusY="4"
                               Fill="#1C1C1C" Stroke="#FFD700" StrokeThickness="1.5"/>
                    <!-- DRS flap -->
                    <Rectangle Canvas.Left="388" Canvas.Top="482"
                               Width="184" Height="10"
                               RadiusX="2" RadiusY="2"
                               Fill="#252525" Stroke="#888" StrokeThickness="1"/>
                    <!-- End plates L -->
                    <Rectangle Canvas.Left="376" Canvas.Top="458"
                               Width="10" Height="38"
                               RadiusX="2" RadiusY="2"
                               Fill="#1C1C1C" Stroke="#FFD700" StrokeThickness="1"/>
                    <!-- End plates R -->
                    <Rectangle Canvas.Left="574" Canvas.Top="458"
                               Width="10" Height="38"
                               RadiusX="2" RadiusY="2"
                               Fill="#1C1C1C" Stroke="#FFD700" StrokeThickness="1"/>
                    <!-- Swan-neck mounts -->
                    <Line X1="432" Y1="455" X2="432" Y2="460" Stroke="#AAA" StrokeThickness="2"/>
                    <Line X1="480" Y1="453" X2="480" Y2="460" Stroke="#AAA" StrokeThickness="2"/>
                    <Line X1="528" Y1="455" X2="528" Y2="460" Stroke="#AAA" StrokeThickness="2"/>

                    <!-- SUSPENSION ARMS (wishbones) — front -->
                    <!-- FL upper arm -->
                    <Line X1="398" Y1="130" X2="336" Y2="148" Stroke="#666" StrokeThickness="2" StrokeEndLineCap="Round"/>
                    <Line X1="398" Y1="148" X2="336" Y2="162" Stroke="#666" StrokeThickness="2" StrokeEndLineCap="Round"/>
                    <!-- FR upper arm -->
                    <Line X1="562" Y1="130" X2="624" Y2="148" Stroke="#666" StrokeThickness="2" StrokeEndLineCap="Round"/>
                    <Line X1="562" Y1="148" X2="624" Y2="162" Stroke="#666" StrokeThickness="2" StrokeEndLineCap="Round"/>

                    <!-- SUSPENSION ARMS — rear -->
                    <!-- RL upper arm -->
                    <Line X1="398" Y1="360" X2="336" Y2="388" Stroke="#666" StrokeThickness="2" StrokeEndLineCap="Round"/>
                    <Line X1="398" Y1="378" X2="336" Y2="402" Stroke="#666" StrokeThickness="2" StrokeEndLineCap="Round"/>
                    <!-- RR upper arm -->
                    <Line X1="562" Y1="360" X2="624" Y2="388" Stroke="#666" StrokeThickness="2" StrokeEndLineCap="Round"/>
                    <Line X1="562" Y1="378" X2="624" Y2="402" Stroke="#666" StrokeThickness="2" StrokeEndLineCap="Round"/>

                    <!-- ─────────────────────────────────────────────
                         TYRES  (top-view: wide flat rectangles with rounded ends)
                         Tyre centre positions:
                           FL: cx=310, cy=155   FR: cx=650, cy=155
                           RL: cx=310, cy=395   RR: cx=650, cy=395
                         Tyre: width=72 (lateral), height=108 (circumference)
                    ───────────────────────────────────────────── -->

                    <!-- FL tyre -->
                    <Rectangle Canvas.Left="274" Canvas.Top="101"
                               Width="72" Height="108"
                               RadiusX="18" RadiusY="18"
                               Fill="#222" Stroke="#888" StrokeThickness="2"/>
                    <!-- FL rim/wheel face (inner ellipse) -->
                    <Ellipse Canvas.Left="289" Canvas.Top="116"
                             Width="42" Height="78"
                             Fill="#181818" Stroke="#555" StrokeThickness="1"/>
                    <!-- FL rim spokes -->
                    <Line X1="310" Y1="121" X2="310" Y2="189" Stroke="#444" StrokeThickness="1.5"/>
                    <Line X1="293" Y1="133" X2="327" Y2="177" Stroke="#444" StrokeThickness="1.5"/>
                    <Line X1="293" Y1="177" X2="327" Y2="133" Stroke="#444" StrokeThickness="1.5"/>
                    <Ellipse Canvas.Left="300" Canvas.Top="145"
                             Width="20" Height="20"
                             Fill="#111" Stroke="#666" StrokeThickness="1"/>

                    <!-- FR tyre -->
                    <Rectangle Canvas.Left="614" Canvas.Top="101"
                               Width="72" Height="108"
                               RadiusX="18" RadiusY="18"
                               Fill="#222" Stroke="#888" StrokeThickness="2"/>
                    <Ellipse Canvas.Left="629" Canvas.Top="116"
                             Width="42" Height="78"
                             Fill="#181818" Stroke="#555" StrokeThickness="1"/>
                    <Line X1="650" Y1="121" X2="650" Y2="189" Stroke="#444" StrokeThickness="1.5"/>
                    <Line X1="633" Y1="133" X2="667" Y2="177" Stroke="#444" StrokeThickness="1.5"/>
                    <Line X1="633" Y1="177" X2="667" Y2="133" Stroke="#444" StrokeThickness="1.5"/>
                    <Ellipse Canvas.Left="640" Canvas.Top="145"
                             Width="20" Height="20"
                             Fill="#111" Stroke="#666" StrokeThickness="1"/>

                    <!-- RL tyre -->
                    <Rectangle Canvas.Left="274" Canvas.Top="341"
                               Width="72" Height="108"
                               RadiusX="18" RadiusY="18"
                               Fill="#222" Stroke="#888" StrokeThickness="2"/>
                    <Ellipse Canvas.Left="289" Canvas.Top="356"
                             Width="42" Height="78"
                             Fill="#181818" Stroke="#555" StrokeThickness="1"/>
                    <Line X1="310" Y1="361" X2="310" Y2="429" Stroke="#444" StrokeThickness="1.5"/>
                    <Line X1="293" Y1="373" X2="327" Y2="417" Stroke="#444" StrokeThickness="1.5"/>
                    <Line X1="293" Y1="417" X2="327" Y2="373" Stroke="#444" StrokeThickness="1.5"/>
                    <Ellipse Canvas.Left="300" Canvas.Top="385"
                             Width="20" Height="20"
                             Fill="#111" Stroke="#666" StrokeThickness="1"/>

                    <!-- RR tyre -->
                    <Rectangle Canvas.Left="614" Canvas.Top="341"
                               Width="72" Height="108"
                               RadiusX="18" RadiusY="18"
                               Fill="#222" Stroke="#888" StrokeThickness="2"/>
                    <Ellipse Canvas.Left="629" Canvas.Top="356"
                             Width="42" Height="78"
                             Fill="#181818" Stroke="#555" StrokeThickness="1"/>
                    <Line X1="650" Y1="361" X2="650" Y2="429" Stroke="#444" StrokeThickness="1.5"/>
                    <Line X1="633" Y1="373" X2="667" Y2="417" Stroke="#444" StrokeThickness="1.5"/>
                    <Line X1="633" Y1="417" X2="667" Y2="373" Stroke="#444" StrokeThickness="1.5"/>
                    <Ellipse Canvas.Left="640" Canvas.Top="385"
                             Width="20" Height="20"
                             Fill="#111" Stroke="#666" StrokeThickness="1"/>

                    <!-- ─────────────────────────────────────────────
                         CONNECTOR LINES: tyre edge → data panel
                    ───────────────────────────────────────────── -->
                    <!-- FL line: from left edge of FL tyre (274,155) → right edge of FL panel (270,155) -->
                    <Line X1="274" Y1="155" X2="260" Y2="155"
                          Stroke="#FFD700" StrokeThickness="1" StrokeDashArray="4 3"/>
                    <!-- FR line: from right edge of FR tyre (686,155) → left edge of FR panel (700,155) -->
                    <Line X1="686" Y1="155" X2="700" Y2="155"
                          Stroke="#FFD700" StrokeThickness="1" StrokeDashArray="4 3"/>
                    <!-- RL line -->
                    <Line X1="274" Y1="395" X2="260" Y2="395"
                          Stroke="#FFD700" StrokeThickness="1" StrokeDashArray="4 3"/>
                    <!-- RR line -->
                    <Line X1="686" Y1="395" X2="700" Y2="395"
                          Stroke="#FFD700" StrokeThickness="1" StrokeDashArray="4 3"/>

                    <!-- ─────────────────────────────────────────────
                         DATA PANELS — each 180 × 110, positioned at corners
                         FL: right edge at x=260, centre y=155 → left=80, top=100
                         FR: left edge at x=700, centre y=155 → left=700, top=100
                         RL: left=80, top=340
                         RR: left=700, top=340
                    ───────────────────────────────────────────── -->

                    <!-- FRONT LEFT panel -->
                    <Border Width="185" Height="110"
                            Background="#111111"
                            BorderBrush="#FFD700"
                            BorderThickness="2"
                            CornerRadius="10"
                            Canvas.Left="75"
                            Canvas.Top="100"
                            Padding="10">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Front Left"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding FLWheelspeed, StringFormat={}{0:F1} km/h}"
                                       Foreground="#FFD700"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,2"/>
                            <TextBlock Text="{Binding FLBrakeTemp, StringFormat=Brake: {0} °C}"
                                       Foreground="#AAAAAA"
                                       FontSize="13"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- FRONT RIGHT panel -->
                    <Border Width="185" Height="110"
                            Background="#111111"
                            BorderBrush="#FFD700"
                            BorderThickness="2"
                            CornerRadius="10"
                            Canvas.Left="700"
                            Canvas.Top="100"
                            Padding="10">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Front Right"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding FRWheelspeed, StringFormat={}{0:F1} km/h}"
                                       Foreground="#FFD700"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,2"/>
                            <TextBlock Text="{Binding FRBrakeTemp, StringFormat=Brake: {0} °C}"
                                       Foreground="#AAAAAA"
                                       FontSize="13"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- REAR LEFT panel -->
                    <Border Width="185" Height="110"
                            Background="#111111"
                            BorderBrush="#FFD700"
                            BorderThickness="2"
                            CornerRadius="10"
                            Canvas.Left="75"
                            Canvas.Top="340"
                            Padding="10">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Rear Left"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding RLWheelspeed, StringFormat={}{0:F1} km/h}"
                                       Foreground="#FFD700"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,2"/>
                            <TextBlock Text="{Binding RLBrakeTemp, StringFormat=Brake: {0} °C}"
                                       Foreground="#AAAAAA"
                                       FontSize="13"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- REAR RIGHT panel -->
                    <Border Width="185" Height="110"
                            Background="#111111"
                            BorderBrush="#FFD700"
                            BorderThickness="2"
                            CornerRadius="10"
                            Canvas.Left="700"
                            Canvas.Top="340"
                            Padding="10">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Rear Right"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding RRWheelspeed, StringFormat={}{0:F1} km/h}"
                                       Foreground="#FFD700"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,2"/>
                            <TextBlock Text="{Binding RRBrakeTemp, StringFormat=Brake: {0} °C}"
                                       Foreground="#AAAAAA"
                                       FontSize="13"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- ─────────────────────────────────────────────
                         DIRECTION ARROW at nose tip
                    ───────────────────────────────────────────── -->
                    <Polygon Points="480,0 472,16 488,16"
                             Fill="#FFD700" Opacity="0.7"/>

                </Canvas>
            </Grid>

            <!-- ══════════════════════════════════════
                 Summary bar
            ══════════════════════════════════════ -->
            <UniformGrid Grid.Row="2" Columns="4" Margin="0,16,0,0">
                <Border BorderBrush="#FFD700" BorderThickness="1" CornerRadius="8" Margin="6" Padding="12">
                    <StackPanel>
                        <TextBlock Text="FL" Foreground="#888" FontSize="14" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding FLWheelspeed, StringFormat={}{0:F1}}"
                                   Foreground="#FFD700" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="km/h" Foreground="#555" FontSize="11" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border BorderBrush="#FFD700" BorderThickness="1" CornerRadius="8" Margin="6" Padding="12">
                    <StackPanel>
                        <TextBlock Text="FR" Foreground="#888" FontSize="14" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding FRWheelspeed, StringFormat={}{0:F1}}"
                                   Foreground="#FFD700" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="km/h" Foreground="#555" FontSize="11" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border BorderBrush="#FFD700" BorderThickness="1" CornerRadius="8" Margin="6" Padding="12">
                    <StackPanel>
                        <TextBlock Text="RL" Foreground="#888" FontSize="14" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding RLWheelspeed, StringFormat={}{0:F1}}"
                                   Foreground="#FFD700" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="km/h" Foreground="#555" FontSize="11" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border BorderBrush="#FFD700" BorderThickness="1" CornerRadius="8" Margin="6" Padding="12">
                    <StackPanel>
                        <TextBlock Text="RR" Foreground="#888" FontSize="14" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding RRWheelspeed, StringFormat={}{0:F1}}"
                                   Foreground="#FFD700" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="km/h" Foreground="#555" FontSize="11" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

        </Grid>
    </ScrollViewer>
</Page>
