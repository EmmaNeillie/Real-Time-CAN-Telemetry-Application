<Window x:Class="WPF_CAN_Tool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_CAN_Tool"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Background="Black">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="UGRacing CAN Display" Foreground="#FFD700" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,20,0,20"/>
        
        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            
            <Border Grid.Row="0" Grid.Column="0" BorderBrush="#FFD700" BorderThickness="2" Margin="5">
                <TextBlock Text="Block 1" Foreground="#FFD700" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
            </Border>
            <Border Grid.Row="0" Grid.Column="1" BorderBrush="#FFD700" BorderThickness="2" Margin="5">
                <TextBlock Text="Block 2" Foreground="#FFD700" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
            </Border>
            <Border Grid.Row="0" Grid.Column="2" BorderBrush="#FFD700" BorderThickness="2" Margin="5">
                <TextBlock Text="Block 3" Foreground="#FFD700" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
            </Border>
            <Border Grid.Row="1" Grid.Column="0" BorderBrush="#FFD700" BorderThickness="2" Margin="5">
                <TextBlock Text="Block 4" Foreground="#FFD700" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
            </Border>
            <Border Grid.Row="1" Grid.Column="1" BorderBrush="#FFD700" BorderThickness="2" Margin="5">
                <TextBlock Text="Block 5" Foreground="#FFD700" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
            </Border>
            <Border Grid.Row="1" Grid.Column="2" BorderBrush="#FFD700" BorderThickness="2" Margin="5">
                <TextBlock Text="Block 6" Foreground="#FFD700" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
            </Border>
        </Grid>
    </Grid>
</Window>
