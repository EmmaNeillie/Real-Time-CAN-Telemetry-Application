<Window x:Class="WPF_CAN_Tool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="UGRacing CAN Display"
        Height="800"
        Width="1300"
        Background="#0F0F0F">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left navigation -->
        <Border Grid.Column="0" Background="#151515" BorderBrush="#FFD700" BorderThickness="0,0,2,0">
            <StackPanel>
                <TextBlock Text="UGRacing"
                           Foreground="#FFD700"
                           FontSize="28"
                           FontWeight="Bold"
                           Margin="20,20,20,30"/>

                <Button Content="LV Overview"
                        Height="50"
                        Margin="15,8"
                        Click="LvOverview_Click"/>

                <Button Content="TS Overview"
                    Height="50"
                    Margin="15,8"
                    Click="TsOverview_Click"/>

                <Button Content="Pedals"
                        Height="50"
                        Margin="15,8"
                        Click="Pedals_Click"/>

                <Button Content="SDC"
                        Height="50"
                        Margin="15,8"
                        Click="Sdc_Click"/>

                <Button Content="Wheelspeeds"
                        Height="50"
                        Margin="15,8"
                        Click="Wheelspeeds_Click"/>

                <Separator Margin="15,20,15,12" Background="#FFD700"/>

                <TextBlock Text="CAN Log"
                           Foreground="#FFD700"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="20,0,20,8"/>

                <Button x:Name="StartRecordingButton"
                        Content="Start Recording"
                        Height="40"
                        Margin="15,6"
                        Click="StartRecording_Click"/>

                <Button x:Name="StopRecordingButton"
                        Content="Stop Recording"
                        Height="40"
                        Margin="15,6"
                        IsEnabled="False"
                        Click="StopRecording_Click"/>

                <Button Content="Playback Log"
                        Height="40"
                        Margin="15,6"
                        Click="PlaybackLog_Click"/>

            </StackPanel>
        </Border>

        <!-- Active page -->
        <Frame x:Name="MainFrame"
               Grid.Column="1"
               NavigationUIVisibility="Hidden"
               Background="Black"/>
    </Grid>
</Window>
