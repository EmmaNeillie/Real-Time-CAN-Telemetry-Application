<Page x:Class="WPF_CAN_Tool.Pages.SdcPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="SDC"
      Background="Black">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="SDC"
                       Foreground="#FFD700"
                       FontSize="34"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <Border Grid.Row="1" BorderBrush="#FFD700" BorderThickness="2" CornerRadius="8" Padding="12" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="SDC Overview"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Green = high / true / OK, Red = low / false / fault"
                               Foreground="White"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <WrapPanel Grid.Row="2"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,20">

                <!-- LVMS -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="100" Height="50" Margin="4" CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Red"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LvmsOk}" Value="True">
                                        <Setter Property="Background" Value="LimeGreen"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="LVMS" Foreground="Black" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Rectangle Width="16" Height="3" Fill="White" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- BSPD -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="100" Height="50" Margin="4" CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Red"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding BspdOk}" Value="True">
                                        <Setter Property="Background" Value="LimeGreen"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="BSPD" Foreground="Black" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Rectangle Width="16" Height="3" Fill="White" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Kill Switch -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="100" Height="50" Margin="4" CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Red"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding KillSwitchOk}" Value="True">
                                        <Setter Property="Background" Value="LimeGreen"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="Kill Switch" Foreground="Black" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   TextWrapping="Wrap" TextAlignment="Center"/>
                    </Border>
                    <Rectangle Width="16" Height="3" Fill="White" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Inertia Switch -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="100" Height="50" Margin="4" CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Red"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding InertiaOk}" Value="True">
                                        <Setter Property="Background" Value="LimeGreen"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="Inertia Switch" Foreground="Black" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   TextWrapping="Wrap" TextAlignment="Center"/>
                    </Border>
                    <Rectangle Width="16" Height="3" Fill="White" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- BOTS -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="100" Height="50" Margin="4" CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Red"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding BotsOk}" Value="True">
                                        <Setter Property="Background" Value="LimeGreen"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="BOTS" Foreground="Black" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Rectangle Width="16" Height="3" Fill="White" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- APPS -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="100" Height="50" Margin="4" CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Red"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AppsOk}" Value="True">
                                        <Setter Property="Background" Value="LimeGreen"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="APPS" Foreground="Black" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Rectangle Width="16" Height="3" Fill="White" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- LHS SB -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="100" Height="50" Margin="4" CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Red"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LhsSbOk}" Value="True">
                                        <Setter Property="Background" Value="LimeGreen"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="LHS SB" Foreground="Black" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Rectangle Width="16" Height="3" Fill="White" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- RHS SB -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="100" Height="50" Margin="4" CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Red"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RhsSbOk}" Value="True">
                                        <Setter Property="Background" Value="LimeGreen"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="RHS SB" Foreground="Black" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Rectangle Width="16" Height="3" Fill="White" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Latchboard -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="100" Height="50" Margin="4" CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Red"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LatchboardOk}" Value="True">
                                        <Setter Property="Background" Value="LimeGreen"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="Latchboard" Foreground="Black" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   TextWrapping="Wrap" TextAlignment="Center"/>
                    </Border>
                    <Rectangle Width="16" Height="3" Fill="White" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- DC -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="100" Height="50" Margin="4" CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Red"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DcOk}" Value="True">
                                        <Setter Property="Background" Value="LimeGreen"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="DC" Foreground="Black" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Rectangle Width="16" Height="3" Fill="White" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- HVD -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="100" Height="50" Margin="4" CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Red"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HvdOk}" Value="True">
                                        <Setter Property="Background" Value="LimeGreen"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="HVD" Foreground="Black" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Rectangle Width="16" Height="3" Fill="White" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- MC -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="100" Height="50" Margin="4" CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Red"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding McOk}" Value="True">
                                        <Setter Property="Background" Value="LimeGreen"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="MC" Foreground="Black" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Rectangle Width="16" Height="3" Fill="White" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Self Latch -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="100" Height="50" Margin="4" CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Red"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelfLatchOk}" Value="True">
                                        <Setter Property="Background" Value="LimeGreen"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="Self Latch" Foreground="Black" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   TextWrapping="Wrap" TextAlignment="Center"/>
                    </Border>
                    <Rectangle Width="16" Height="3" Fill="White" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- TSAL Switch -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="100" Height="50" Margin="4" CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Red"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TsalSwitchOk}" Value="True">
                                        <Setter Property="Background" Value="LimeGreen"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="TSAL Switch" Foreground="Black" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   TextWrapping="Wrap" TextAlignment="Center"/>
                    </Border>
                    <Rectangle Width="16" Height="3" Fill="White" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- TSMS -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="100" Height="50" Margin="4" CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Red"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TsmsOk}" Value="True">
                                        <Setter Property="Background" Value="LimeGreen"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="TSMS" Foreground="Black" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Rectangle Width="16" Height="3" Fill="White" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Precharge -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="100" Height="50" Margin="4" CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Red"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PrechargeOk}" Value="True">
                                        <Setter Property="Background" Value="LimeGreen"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="Precharge" Foreground="Black" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Rectangle Width="16" Height="3" Fill="White" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- AIRs / Contactors (output — no trailing connector) -->
                <Border Width="120" Height="50" Margin="4" CornerRadius="6" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Red"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding LvmsOk}" Value="True"/>
                                        <Condition Binding="{Binding BspdOk}" Value="True"/>
                                        <Condition Binding="{Binding KillSwitchOk}" Value="True"/>
                                        <Condition Binding="{Binding InertiaOk}" Value="True"/>
                                        <Condition Binding="{Binding BotsOk}" Value="True"/>
                                        <Condition Binding="{Binding AppsOk}" Value="True"/>
                                        <Condition Binding="{Binding LhsSbOk}" Value="True"/>
                                        <Condition Binding="{Binding RhsSbOk}" Value="True"/>
                                        <Condition Binding="{Binding LatchboardOk}" Value="True"/>
                                        <Condition Binding="{Binding DcOk}" Value="True"/>
                                        <Condition Binding="{Binding HvdOk}" Value="True"/>
                                        <Condition Binding="{Binding McOk}" Value="True"/>
                                        <Condition Binding="{Binding SelfLatchOk}" Value="True"/>
                                        <Condition Binding="{Binding TsalSwitchOk}" Value="True"/>
                                        <Condition Binding="{Binding TsmsOk}" Value="True"/>
                                        <Condition Binding="{Binding PrechargeOk}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Background" Value="LimeGreen"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="AIRs" Foreground="Black" FontWeight="Bold" FontSize="13"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center" Padding="4"/>
                </Border>

            </WrapPanel>

        </Grid>
    </ScrollViewer>
</Page>